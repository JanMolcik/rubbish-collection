# Public base URL used for metadata and canonical links.
NEXT_PUBLIC_SITE_URL=https://rubbish-collection.vercel.app

# CSP frame-ancestors value for /embed route.
# Use explicit domains in production when possible, for example:
# NEXT_PUBLIC_EMBED_FRAME_ANCESTORS='https://www.obeclipa.cz https://obeclipa.cz'
NEXT_PUBLIC_EMBED_FRAME_ANCESTORS=*
